# =============================================
# .dockerignore — Monorepo
# Evitar copiar archivos innecesarios al contexto de Docker
# =============================================

# Git
.git
.gitignore

# Dependencias (se instalan dentro del contenedor)
node_modules
**/node_modules

# Entornos virtuales de Python
venv
.venv
__pycache__
*.pyc

# Variables de entorno
# (Se incluyen en prod para que el contenedor arranque con todas las credenciales)

# IDE
.vscode
.idea

# Documentación
*.md
!README.md

# Archivos temporales
*.log
*.tmp
uploads/*

# Mobile (no se necesita en los contenedores de backend)
mobile/

# Modelos Whisper (IAService)
IAService/models_whisper/

# Firebase / credenciales — Se incluyen en la imagen de producción
# (En desarrollo se montan como volúmenes)
